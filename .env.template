# Server Configuration
PORT=3000
NODE_ENV=development

# Simulation Toggles
# Set to 'false' to use live API integrations. Set to 'true' to run fully simulated workflows.
SIMULATION_MODE=true

# API Keys
# Optional: Google Gemini API key for smart caption and content generation
GEMINI_API_KEY=
# Optional: NewsAPI key (from newsapi.org) for advanced news aggregation
NEWS_API_KEY=

# Meta/Instagram API Configuration (Required for live mode)
# Instagram Business Account ID
INSTAGRAM_ACCOUNT_ID=
# Instagram Graph API Access Token
INSTAGRAM_ACCESS_TOKEN=
# Publicly accessible URL of this server (Required for Meta API to fetch images, e.g., Ngrok URL or domain name)
SERVER_PUBLIC_URL=

